<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <!--
      net10.0-windows because Office COM interop is Windows-only.
      The TargetFramework was net10.0 from the template; bumped to the
      windows variant so we can reference the Office PIAs.
    -->
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CueBooth.Sidecar</RootNamespace>
    <AssemblyName>cuebooth-sidecar</AssemblyName>
    <Description>CueBooth PowerPoint COM sidecar — forwards slide-change events to the Go server.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
    <!--
      Office.Interop.PowerPoint is the Office PIA. It resolves on Windows
      build hosts that have Office installed or via the redistributable
      PIA package. Local non-Windows builds will not restore the COM
      types; production builds happen via GHA on a windows-latest runner.
    -->
    <PackageReference Include="Microsoft.Office.Interop.PowerPoint" Version="15.0.4420.1018" />
  </ItemGroup>
</Project>
